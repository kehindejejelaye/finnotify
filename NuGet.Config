<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Clear all inherited sources (this is the key fix) -->
    <clear />

    <!-- Use only the default public NuGet feed -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>