{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Keycloak": {
    "BaseUrl": "http://localhost:8080",

    "PlatformRealm": "platform-admin",
    "PlatformClientId": "platform-backend",
    "PlatformClientSecret": "platform-secret",

    "AppRealm": "app",
    "AppClientId": "backend-service",
    "AppClientSecret": "backend-secret"
  },

  "KeycloakJwtOptions": {
    "ValidIssuers": [
      "http://localhost:8080/realms/platform-admin",
      "http://localhost:8080/realms/app"
    ],
    "ValidAudiences": [
      "platform-admin-frontend",
      "tenant-frontend",
      "backend-service",
      "platform-backend"
    ]
  }
}