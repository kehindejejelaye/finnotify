{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "BaseUrl": "https://localhost:8080",
    "Realm": "myrealm",
    "ClientId": "my-client",
    "ClientSecret": "secret123"
  },
  "KeycloakJwtOptions": {
    "ValidIssuers": [
      "http://localhost:8080/realms/platform-admin",
      "http://localhost:8080/realms/app"
    ],
    "ValidAudiences": [
      "backend-service",
      "tenant-frontend",
      "enduser-frontend"
    ]
  }
}
